/**
 * Get icon using comprehensive keyword matching
 */
export function getIconByKeywords(name, isMainCategory = false) {
  if (!name) return '📦';
  
  const normalized = name.toLowerCase().trim();
  
  // Check main categories first
  if (isMainCategory) {
    return MAIN_CATEGORY_ICONS[normalized] || '📦';
  }
  
  // Check keyword matches (most specific first due to array order)
  for (const { keywords, icon } of ICON_KEYWORDS) {
    for (const keyword of keywords) {
      if (normalized === keyword || normalized.includes(keyword)) {
        return icon;
      }
    }
  }
  
  return '📦'; // Default
}

/**
 * Get placeholder image - using a reliable service
 */
export function getStockImage(subcategoryName) {
  if (!subcategoryName) return '';
  
  const name = subcategoryName.toLowerCase();
  
  // Map to appropriate image categories
  const categoryMap = {
    'automotive': 'car',
    'car': 'car',
    'vehicle': 'car',
    'motorbike': 'motorcycle',
    'motorcycle': 'motorcycle',
    
    'book': 'books',
    'music': 'music',
    'movie': 'cinema',
    'film': 'cinema',
    
    'clothing': 'fashion',
    'fashion': 'fashion',
    'dress': 'dress',
    'shirt': 'fashion',
    'shoes': 'shoes',
    'jewelry': 'jewelry',
    'jewellery': 'jewelry',
    'watch': 'watch',
    'bag': 'bag',
    
    'computer': 'technology',
    'laptop': 'laptop',
    'gaming': 'gaming',
    'hardware': 'technology',
    
    'phone': 'smartphone',
    'mobile': 'smartphone',
    'camera': 'camera',
    'tv': 'television',
    'audio': 'headphones',
    'speaker': 'speakers',
    'headphone': 'headphones',
    
    'food': 'food',
    'drink': 'drinks',
    'wine': 'wine',
    'beer': 'beer',
    'gift': 'gift',
    
    'beauty': 'beauty',
    'cosmetic': 'cosmetics',
    'makeup': 'makeup',
    'skincare': 'skincare',
    'health': 'health',
    
    'kitchen': 'kitchen',
    'furniture': 'furniture',
    'garden': 'garden',
    'home': 'home',
    'pet': 'pets',
    
    'toy': 'toys',
    'game': 'games',
    'baby': 'baby'
  };
  
  // Find matching category
  let imageCategory = 'product';
  for (const [key, value] of Object.entries(categoryMap)) {
    if (name.includes(key)) {
      imageCategory = value;
      break;
    }
  }
  
  // Use placeholder.com - more reliable than Unsplash for consistent images
  return `https://via.placeholder.com/400x150/4A90E2/FFFFFF?text=${encodeURIComponent(subcategoryName)}`;
}
